{
  "manifest_version": "0.4",
  "name": "@nimblebraininc/synapse-crm",
  "version": "0.2.0",
  "description": "Lightweight contact and deal tracker with agent-driven follow-ups and pipeline reviews.",
  "author": {
    "name": "NimbleBrain Inc."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NimbleBrainInc/synapse-crm"
  },
  "server": {
    "type": "python",
    "entry_point": "synapse_crm.server",
    "mcp_config": {
      "command": "python",
      "args": [
        "-m",
        "synapse_crm.server"
      ]
    }
  },
  "_meta": {
    "org.mpaktrust": {
      "mtf_version": "0.1",
      "permissions": {
        "filesystem": "read",
        "network": "none",
        "environment": "read",
        "subprocess": "none",
        "native": "none"
      }
    },
    "ai.nimblebrain/host": {
      "host_version": "1.0",
      "name": "CRM",
      "icon": "users",
      "category": "sales",
      "placements": [
        {
          "slot": "sidebar.apps",
          "resourceUri": "ui://crm/main",
          "route": "@nimblebraininc/synapse-crm",
          "label": "CRM",
          "icon": "users"
        }
      ],
      "briefing": {
        "priority": "high",
        "facets": [
          {
            "name": "pipeline_movement",
            "label": "Pipeline",
            "type": "delta",
            "entity": "deal",
            "query": {
              "updated_at": {
                "$gte": "${period.since}"
              }
            },
            "description": "Deals that moved stages"
          },
          {
            "name": "overdue_followups",
            "label": "Follow-ups",
            "type": "attention",
            "entity": "interaction",
            "query": {
              "follow_up_date": {
                "$lt": "${now}",
                "$ne": null
              }
            },
            "metric": "count",
            "description": "Follow-ups past their due date"
          },
          {
            "name": "new_contacts",
            "label": "New contacts",
            "type": "activity",
            "entity": "contact",
            "query": {
              "created_at": {
                "$gte": "${period.since}"
              }
            },
            "metric": "count",
            "description": "Contacts added in this period"
          }
        ]
      }
    },
    "ai.nimblebrain/upjack": {
      "upjack_version": "0.1",
      "namespace": "apps/crm",
      "display": {
        "name": "CRM",
        "icon": "users",
        "category": "sales"
      },
      "entities": [
        {
          "name": "contact",
          "plural": "contacts",
          "schema": "schemas/contact.schema.json",
          "prefix": "ct",
          "index": true,
          "tools": [
            "get",
            "update",
            "list",
            "search",
            "delete",
            "query_by_relationship",
            "get_related",
            "get_composite"
          ]
        },
        {
          "name": "deal",
          "plural": "deals",
          "schema": "schemas/deal.schema.json",
          "prefix": "dl",
          "index": true
        },
        {
          "name": "interaction",
          "plural": "interactions",
          "schema": "schemas/interaction.schema.json",
          "prefix": "ix",
          "index": true
        }
      ],
      "skills": [
        {
          "source": "bundled",
          "path": "skills/follow-up-coach/SKILL.md"
        },
        {
          "source": "bundled",
          "path": "skills/pipeline-reviewer/SKILL.md"
        }
      ],
      "hooks": [
        {
          "event": "entity.created",
          "entity": "interaction",
          "skill": "bundled:follow-up-coach"
        },
        {
          "event": "entity.updated",
          "entity": "deal",
          "condition": "$.stage changed",
          "skill": "bundled:follow-up-coach"
        }
      ],
      "schedules": [
        {
          "name": "daily-pipeline-review",
          "cron": "0 9 * * 1-5",
          "skill": "bundled:pipeline-reviewer",
          "description": "Weekday morning review of pipeline health, stale deals, and overdue follow-ups."
        }
      ],
      "views": [
        {
          "name": "active-pipeline",
          "entity": "deal",
          "description": "All active deals sorted by value (highest first)",
          "filter": "$.status == 'active'",
          "sort": "-value"
        },
        {
          "name": "needs-followup",
          "entity": "interaction",
          "description": "Interactions with overdue or upcoming follow-up dates",
          "filter": "$.follow_up_date != null",
          "sort": "follow_up_date"
        },
        {
          "name": "recent-interactions",
          "entity": "interaction",
          "description": "Most recent interactions across all contacts",
          "filter": "$.status == 'active'",
          "sort": "-occurred_at"
        }
      ],
      "context": "context.md",
      "seed": {
        "data": "seed/",
        "run_on_install": true
      }
    }
  }
}
